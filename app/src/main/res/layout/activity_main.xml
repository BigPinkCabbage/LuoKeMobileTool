<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E1"
    android:orientation="vertical">

    <!-- 顶部两个功能切换按钮（一排两个） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnTabAim"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="抓宠准心"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="#4CAF50"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnTabSunflower"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="刷向阳花"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="#9E9E9E"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 页面1：抓宠准心 -->
    <ScrollView
        android:id="@+id/scrollViewAim"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 准心样式选择行 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="选择准心样式"
                android:textSize="15sp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <!-- 十字样式 -->
                <FrameLayout
                    android:id="@+id/frameCross"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <Button
                        android:id="@+id/btnStyleCross"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/btn_style_unselected"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:clickable="false"
                        android:focusable="false" />

                    <ImageView
                        android:id="@+id/imgCross"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="center" />
                </FrameLayout>

                <!-- 圆形样式 -->
                <FrameLayout
                    android:id="@+id/frameCircle"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <Button
                        android:id="@+id/btnStyleCircle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/btn_style_unselected"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:clickable="false"
                        android:focusable="false" />

                    <ImageView
                        android:id="@+id/imgCircle"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="center" />
                </FrameLayout>

                <!-- 四角框样式 -->
                <FrameLayout
                    android:id="@+id/frameBracket"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <Button
                        android:id="@+id/btnStyleBracket"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/btn_style_unselected"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:clickable="false"
                        android:focusable="false" />

                    <ImageView
                        android:id="@+id/imgBracket"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="center" />
                </FrameLayout>

                <!-- 点样式 -->
                <FrameLayout
                    android:id="@+id/frameDot"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <Button
                        android:id="@+id/btnStyleDot"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/btn_style_unselected"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:clickable="false"
                        android:focusable="false" />

                    <ImageView
                        android:id="@+id/imgDot"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="center" />
                </FrameLayout>
            </LinearLayout>

            <!-- 颜色选择行 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="准心颜色"
                android:textSize="15sp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnColorBlack"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnColorWhite"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:textColor="#000000" />

                <Button
                    android:id="@+id/btnColorRed"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnColorYellow"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:textColor="#000000" />

                <Button
                    android:id="@+id/btnColorGreen"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- 大小调节 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="准心大小调节"
                android:textSize="15sp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <SeekBar
                    android:id="@+id/sizeBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/sizeValue"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="40px"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:gravity="end"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- 透明度调节 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="准心透明度调节"
                android:textSize="15sp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <SeekBar
                    android:id="@+id/alphaBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/alphaValue"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:gravity="end"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- 位置调节 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="准心位置调节"
                android:textSize="15sp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="水平偏移"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <Button
                        android:id="@+id/offsetXSub"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="-"
                        android:textSize="20sp"
                        android:background="#ff9800"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:textColor="#ffffff"
                        android:textStyle="bold" />
                    <SeekBar
                        android:id="@+id/offsetXBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp" />
                    <Button
                        android:id="@+id/offsetXAdd"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="+"
                        android:textSize="20sp"
                        android:background="#ff9800"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:textColor="#ffffff"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/offsetXInput"
                        android:layout_width="60dp"
                        android:layout_height="44dp"
                        android:hint="数值"
                        android:inputType="number"
                        android:textAlignment="center"
                        android:layout_marginStart="4dp"
                        android:background="#E0E0E0"
                        android:padding="4dp" />
                    <Button
                        android:id="@+id/offsetXBtn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="✓"
                        android:textSize="14sp"
                        android:background="#4CAF50"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:textColor="#ffffff"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="垂直偏移"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <Button
                        android:id="@+id/offsetYSub"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="-"
                        android:textSize="20sp"
                        android:background="#ff9800"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:textColor="#ffffff"
                        android:textStyle="bold" />
                    <SeekBar
                        android:id="@+id/offsetYBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp" />
                    <Button
                        android:id="@+id/offsetYAdd"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="+"
                        android:textSize="20sp"
                        android:background="#ff9800"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:textColor="#ffffff"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/offsetYInput"
                        android:layout_width="60dp"
                        android:layout_height="44dp"
                        android:hint="数值"
                        android:inputType="number"
                        android:textAlignment="center"
                        android:layout_marginStart="4dp"
                        android:background="#E0E0E0"
                        android:padding="4dp" />
                    <Button
                        android:id="@+id/offsetYBtn"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="✓"
                        android:textSize="14sp"
                        android:background="#4CAF50"
                        android:backgroundTint="@null"
                        android:stateListAnimator="@null"
                        android:textColor="#ffffff"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 底部两个按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">
                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="保存设置"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="#2196F3"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:layout_marginEnd="8dp" />
                <Button
                    android:id="@+id/btnCloseAim"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="关闭准心"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="#F44336"
                    android:backgroundTint="@null"
                    android:stateListAnimator="@null"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 刷向阳花页面（定时连点器功能） -->
    <LinearLayout
        android:id="@+id/layoutSunflower"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#F5F0E1"
        android:padding="16dp">

        <!-- 第一行：打开悬浮窗按钮 -->
        <Button
            android:id="@+id/btnOpenFloatWindow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="打开悬浮窗"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="#4CAF50"
            android:layout_marginBottom="16dp" />

        <!-- 第二行：添加点击位置 和 删除点击位置（并列一排） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnAddClickPoint"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="添加点击位置"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#2196F3"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnRemoveClickPoint"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="删除点击位置"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#F44336"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 间隔时间输入框 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="启动点击任务间隔时间："
                android:textSize="14sp"
                android:textColor="#000000" />

            <EditText
                android:id="@+id/etIntervalMinutes"
                android:layout_width="80dp"
                android:layout_height="48dp"
                android:inputType="number"
                android:text="1"
                android:textAlignment="center"
                android:background="#E0E0E0"
                android:padding="4dp"
                android:layout_marginStart="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="分钟"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 提示信息 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="提示：点击「添加点击位置」后，屏幕会变灰，点击屏幕任意位置即可添加图标"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</LinearLayout>